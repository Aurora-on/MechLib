{"en_name": "planar force-system equilibrium", "formal_prop_name": null, "id": "law.statics.planar_force_system_equilibrium", "prerequisites": ["concept.force_system", "concept.moment", "statics.equilibrium"], "schema_decls": [], "statement_text": "For a rigid body in planar static equilibrium, the independent force-balance equations and a moment-balance equation vanish.", "status": "schema", "used_for": ["support reaction solving", "free-body equilibrium", "beam and frame statics"], "verified_decls": ["MechLib.RigidBody.Verified.Rotation.torque_def"], "zh_name": "平面力系平衡"}
{"en_name": "Newton's second law", "formal_prop_name": "MechLib.Dynamics.Verified.Dynamics.newton_second_law", "id": "law.dynamics.newton_second_law", "prerequisites": ["foundation.quantity", "kinematics.point_motion"], "schema_decls": [], "statement_text": "The net force on a constant-mass particle is mass times acceleration.", "status": "verified", "used_for": ["particle dynamics", "force analysis", "acceleration constraints"], "verified_decls": ["MechLib.Dynamics.Verified.Dynamics.newton_second_law", "MechLib.Dynamics.Verified.Dynamics.secondLawVec_eq"], "zh_name": "牛顿第二定律"}
{"en_name": "work-energy theorem", "formal_prop_name": "MechLib.Dynamics.Verified.WorkEnergy.work_energy_theorem_core", "id": "law.dynamics.work_energy_theorem", "prerequisites": ["concept.force_system", "dynamics.work_energy"], "schema_decls": [], "statement_text": "The net work done on a body equals the change in kinetic energy.", "status": "verified", "used_for": ["energy methods", "speed from work", "mechanical-energy balance"], "verified_decls": ["MechLib.Dynamics.Verified.WorkEnergy.work_energy_theorem_core", "MechLib.Dynamics.Verified.WorkEnergy.kineticEnergy_change_formula"], "zh_name": "动能定理"}
{"en_name": "principle of virtual work", "formal_prop_name": null, "id": "law.analytical.virtual_work_principle", "prerequisites": ["concept.virtual_displacement", "statics.equilibrium", "analytical.constraints"], "schema_decls": [], "statement_text": "For ideal constraints in static equilibrium, the total virtual work of active forces vanishes for every admissible virtual displacement.", "status": "schema", "used_for": ["constraint-force elimination", "statics by virtual work", "generalized-force modeling"], "verified_decls": [], "zh_name": "虚位移原理"}
{"en_name": "d'Alembert principle", "formal_prop_name": null, "id": "law.analytical.dalembert_principle", "prerequisites": ["concept.virtual_displacement", "law.dynamics.newton_second_law"], "schema_decls": [], "statement_text": "Dynamics can be written as a virtual-work equilibrium by adding inertial forces to the applied-force system.", "status": "schema", "used_for": ["dynamic virtual work", "constraint-force elimination in dynamics", "Lagrange-equation derivation"], "verified_decls": ["MechLib.Dynamics.Verified.Dynamics.newton_second_law"], "zh_name": "达朗贝尔原理"}
{"en_name": "Euler-Lagrange equation", "formal_prop_name": "MechLib.Analytical.LagrangeEquation.SatisfiesEulerLagrange1D", "id": "law.analytical.euler_lagrange_equation", "prerequisites": ["concept.generalized_coordinates", "concept.lagrangian", "analytical.constraints"], "schema_decls": ["MechLib.Analytical.LagrangeEquation.SatisfiesEulerLagrange1D", "MechLib.Analytical.LagrangeEquation.eulerLagrangeResidual1D"], "statement_text": "A trajectory satisfies d/dt(partial L / partial qdot) - partial L / partial q = 0 for each generalized coordinate.", "status": "schema", "used_for": ["Lagrangian modeling", "constrained dynamics", "small-oscillation equations"], "verified_decls": ["MechLib.Analytical.LagrangeEquation.eulerLagrange_iff_newton"], "zh_name": "Euler-Lagrange 方程"}
{"en_name": "Hamilton canonical equations", "formal_prop_name": "MechLib.Analytical.Hamiltonian.CanonicalEquations1D", "id": "law.analytical.hamilton_canonical_equations", "prerequisites": ["concept.generalized_coordinates", "concept.lagrangian"], "schema_decls": ["MechLib.Analytical.Hamiltonian.CanonicalEquations1D"], "statement_text": "Canonical coordinates satisfy qdot = partial H / partial p and pdot = -partial H / partial q.", "status": "schema", "used_for": ["Hamiltonian modeling", "phase-space equations", "canonical dynamics planning"], "verified_decls": ["MechLib.Analytical.Hamiltonian.canonicalEquations1D_eq"], "zh_name": "Hamilton 正则方程"}
{"en_name": "cyclic-coordinate conservation law", "formal_prop_name": "MechLib.Analytical.ConservationLaw.CyclicCoordinateConservation", "id": "law.analytical.cyclic_coordinate_conservation", "prerequisites": ["concept.cyclic_coordinate", "analytical.lagrange_equation", "analytical.conservation_law"], "schema_decls": ["MechLib.Analytical.ConservationLaw.IsCyclicCoordinate", "MechLib.Analytical.ConservationLaw.GeneralizedMomentumConserved", "MechLib.Analytical.ConservationLaw.CyclicCoordinateConservation"], "statement_text": "If a generalized coordinate is cyclic, the conjugate generalized momentum is conserved.", "status": "schema", "used_for": ["identify conserved generalized momentum", "reduce Lagrangian systems", "central-force and symmetry planning"], "verified_decls": ["MechLib.Analytical.ConservationLaw.cyclic_coordinate_implies_momentum_conserved"], "zh_name": "循环坐标守恒律"}
{"en_name": "angular momentum conservation", "formal_prop_name": "MechLib.Mechanics.Rotation.AngularMomentumTheoremParticle", "id": "law.dynamics.angular_momentum_conservation", "prerequisites": ["concept.moment", "dynamics.angular_momentum"], "schema_decls": ["MechLib.Mechanics.Rotation.AngularMomentumTheoremParticle", "MechLib.Mechanics.Rotation.MomentOfMomentumTheoremSystem"], "statement_text": "If the external torque about a point vanishes, the angular momentum about that point is conserved.", "status": "schema", "used_for": ["central-force modeling", "rigid-body angular-momentum balance", "orbit planning"], "verified_decls": ["MechLib.Systems.Verified.CentralForce.hookeCentralForce_torque_zero", "MechLib.Systems.Verified.CentralForce.hookeCentralForce_isCentral"], "zh_name": "角动量守恒"}
{"en_name": "small-oscillation equation", "formal_prop_name": null, "id": "law.analytical.small_oscillation_equation", "prerequisites": ["concept.lagrangian", "concept.kinetic_energy", "concept.potential_energy"], "schema_decls": ["MechLib.Mechanics.SHM.SHMEquation"], "statement_text": "Near a stable equilibrium, the linearized coordinates satisfy a mass-matrix and stiffness-matrix oscillator equation.", "status": "schema", "used_for": ["normal-mode analysis", "coupled oscillator modeling", "linearized stability"], "verified_decls": ["MechLib.Systems.Verified.SHM.acceleration_eq_neg_omega_sq_mul_pos"], "zh_name": "小振动方程"}
